# API base URL (must start with VITE_ for Vite to expose it)
#
# Local dev with backend on :3000 (Vite proxies /api → localhost:3000):
VITE_API_BASE_URL=/api
VITE_WS_URL=
#
# Remote backend (e.g. Render):
VITE_API_BASE_URL=https://studysync-backend-5i2a.onrender.com/api
VITE_WS_URL=https://studysync-backend-5i2a.onrender.com

# Optional: set to true to skip login and use localStorage mocks
# VITE_DEV_BYPASS_AUTH=true
